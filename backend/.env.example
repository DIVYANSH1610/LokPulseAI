# Copy this file to .env and fill in real values.
# Without ANY of the LLM provider keys below set, all agents run in mock
# mode ([MOCK] labels). Set one to go live.
#
# --- Genuinely free, no credit card, no billing account -------------------

# Free forever via Google AI Studio (aistudio.google.com) — sign in with
# any Google account, click "Get API key". ~1,500 requests/day on Flash
# models, no billing required. This alone is enough for a hackathon build.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-flash-latest

# Free registration (email only, no card) at data.gov.in/user/register.
# Replaces BigQuery for public-dataset joins if you don't want to touch
# GCP billing at all — see backend/integrations/datagovin_client.py.
DATA_GOV_IN_API_KEY=

# No API key at all — runs locally via `pip install faster-whisper
# --break-system-packages`. Slower than a cloud API but $0 forever and no
# account needed. See backend/agents/voice_agent.py.
WHISPER_MODEL_SIZE=base

# --- Optional extra LLM fallbacks (check current free-tier limits before relying on these) ---

MISTRAL_API_KEY=
MISTRAL_MODEL=mistral-small-latest

HUGGINGFACE_API_KEY=
HF_GENERATION_MODEL=mistralai/Mistral-7B-Instruct-v0.3
HF_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# --- Everything below requires a GCP project with billing/a card enabled ---
# (Google's free-tier quota for these still requires billing to be turned on —
# unlike Gemini via AI Studio above, which never needs this.)

# Optional — only needed for real Cloud Speech-to-Text (voice_agent.py).
# Prefer faster-whisper above if you want to stay card-free.
GOOGLE_APPLICATION_CREDENTIALS=

# Optional — only needed once BigQuery is wired for real public-dataset
# joins (see backend/integrations/bigquery_client.py). Prefer
# DATA_GOV_IN_API_KEY above if you want to stay card-free.
BIGQUERY_PROJECT_ID=
GOOGLE_APPLICATION_CREDENTIALS_BIGQUERY=

# Optional — defaults to local SQLite if unset.
# Neon (neon.tech) gives a free Postgres tier with no card required.
# Postgres/Neon example: postgresql://user:password@host/dbname
DATABASE_URL=
